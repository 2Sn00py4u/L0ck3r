{
    "manifest_version": 3,
    "name": "L0CK3R",
    "version": "1.0",
    "description": "Secure Password-Manager",
    "permissions": ["activeTab"],
    "action": {
      "default_popup": "html/login.html",
      "default_icon": {
        "16": "assets/icons/icon16.png",
        "48": "assets/icons/icon48.png",
        "128": "assets/icons/icon128.png"
      }
    },
    "background": {
      "service_worker": "js/background.js"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["js/content.js"]
      }
    ]
  }
  